{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "spark-operator": {
      "type": "object",
      "description": "Configuration for the spark-operator subchart",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "registry": {
              "type": "string",
              "default": "ghcr.io",
              "description": "Image registry for spark-operator"
            },
            "repository": {
              "type": "string",
              "default": "netcracker/qubership-spark-operator",
              "description": "Image repository for spark-operator"
            },
            "tag": {
              "type": "string",
              "default": "main",
              "description": "Image tag for spark-operator"
            }
          }
        },
        "openShift": {
          "type": "object",
          "properties": {
            "omit": {
              "type": "boolean",
              "default": true,
              "description": "Specifies whether the security context should be adjusted for OpenShift"
            }
          }
        },
        "controller": {
          "type": "object",
          "description": "Configuration for the spark-operator controller",
          "properties": {
            "podSecurityContext": {
              "description": "Pod-level security context for spark-operator controller pods.",
              "type": "object",
              "$ref": "#/definitions/io.k8s.api.core.v1.PodSecurityContext",
              "default": {
                "runAsNonRoot": true,
                "seccompProfile": {
                  "type": "RuntimeDefault"
                },
                "runAsUser": 185
              }
            },
            "resources": {
              "$ref": "#/definitions/io.k8s.api.core.v1.ResourceRequirements",
              "description": "Compute Resources required by spark-operator controller container. More info: https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/",
              "default": {
                "limits": {
                  "cpu": "200m",
                  "memory": "600Mi"
                },
                "requests": {
                  "cpu": "100m",
                  "memory": "300Mi"
                }
              }
            }
          }
        },
        "webhook": {
          "type": "object",
          "description": "Configuration for the spark-operator webhook",
          "properties": {
            "podSecurityContext": {
              "description": "Pod-level security context for spark-operator webhook pods.",
              "type": "object",
              "$ref": "#/definitions/io.k8s.api.core.v1.PodSecurityContext",
              "default": {
                "runAsNonRoot": true,
                "seccompProfile": {
                  "type": "RuntimeDefault"
                },
                "runAsUser": 185
              }
            },
            "resources": {
              "$ref": "#/definitions/io.k8s.api.core.v1.ResourceRequirements",
              "description": "Compute Resources required by spark-operator webhook container. More info: https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/",
              "default": {
                "limits": {
                  "cpu": "200m",
                  "memory": "600Mi"
                },
                "requests": {
                  "cpu": "100m",
                  "memory": "300Mi"
                }
              }
            }
          }
        },
        "spark": {
          "type": "object",
          "properties": {
            "jobNamespaces": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [
                "spark-apps"
              ],
              "description": "Namespaces where Spark jobs will run"
            },
            "serviceAccount": {
              "type": "object",
              "description": "Service account configuration for Spark jobs.",
              "properties": {
                "name": {
                  "type": "string",
                  "default": "sparkapps-sa"
                }
              }
            }
          }
        },
        "prometheus": {
          "type": "object",
          "properties": {
            "podMonitor": {
              "type": "object",
              "description": "Configuration for the PodMonitor resource for spark-operator.",
              "properties": {
                "create": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether to create the PodMonitor resource."
                },
                "labels": {
                  "type": "object",
                  "description": "Labels to add to the PodMonitor resource for spark-operator. By default, it includes labels to identify the component and its association with platform monitoring.",
                  "default": {
                    "app.kubernetes.io/component": "monitoring",
                    "app.kubernetes.io/name": "spark-operator-gcp-podmonitor",
                    "app.kubernetes.io/part-of": "platform-monitoring",
                    "k8s-app": "spark-operator-gcp-podmonitor"
                  },
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable internal metrics (deprecated)"
        }
      }
    },
    "grafanaApplicationDashboard": {
      "type": "object",
      "properties": {
        "enable": {
          "type": "boolean",
          "default": false,
          "description": "The string to submit a Grafana dashboard for applications"
        }
      }
    },
    "grafanadashboard": {
      "type": "object",
      "properties": {
        "enable": {
          "type": "boolean",
          "default": false,
          "description": "The string to submit a Grafana dashboard"
        }
      }
    },
    "prometheusRules": {
      "type": "object",
      "properties": {
        "alert": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "default": false,
              "description": "Whether to enable Prometheus alerts for spark-operator."
            }
          }
        }
      }
    },
    "appServiceMonitor": {
      "type": "object",
      "properties": {
        "enable": {
          "type": "boolean",
          "default": false,
          "description": "The string to submit a service monitor for Spark applications."
        }
      }
    },
    "spark-history-server": {
      "type": "object",
      "description": "Configuration for the Spark History Server.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "It enables the Spark History Server deployment."
        },
        "openShift": {
          "type": "object",
          "properties": {
            "omit": {
              "type": "boolean",
              "default": true,
              "description": "Specifies whether the security context should be adjusted for OpenShift"
            }
          }
        },
        "securityContext": {
          "type": "object",
          "description": "Container-level security context for the history server Pod.",
          "$ref": "#/definitions/io.k8s.api.core.v1.SecurityContext",
          "default": {
            "allowPrivilegeEscalation": false,
            "capabilities": {
              "drop": [
                "ALL"
              ]
            },
            "readOnlyRootFilesystem": true,
            "runAsNonRoot": true,
            "seccompProfile": {
              "type": "RuntimeDefault"
            }
          }
        },
        "oauth2Proxy": {
          "type": "object",
          "properties": {
            "securityContext": {
              "type": "object",
              "description": "Container-level security context for the oauth2proxy container.",
              "$ref": "#/definitions/io.k8s.api.core.v1.SecurityContext",
              "default": {
                "enable": true,
                "allowPrivilegeEscalation": false,
                "capabilities": {
                  "drop": [
                    "ALL"
                  ]
                },
                "readOnlyRootFilesystem": true,
                "runAsNonRoot": true,
                "seccompProfile": {
                  "type": "RuntimeDefault"
                }
              }
            }
          }
        }
      }
    },
    "spark-thrift-server": {
      "type": "object",
      "description": "Configuration for the Spark Thrift Server.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "It enables the Spark Thrift Server deployment."
        },
        "securityContext": {
          "type": "object",
          "description": "Container-level security context for the spark thrift server Pod.",
          "$ref": "#/definitions/io.k8s.api.core.v1.SecurityContext",
          "default": {
            "allowPrivilegeEscalation": false,
            "capabilities": {
              "drop": [
                "ALL"
              ]
            },
            "readOnlyRootFilesystem": true,
            "runAsNonRoot": true,
            "seccompProfile": {
              "type": "RuntimeDefault"
            },
            "runAsUser": 185
          }
        }
      }
    },
    "spark-integration-tests": {
      "type": "object",
      "properties": {
        "openShift": {
          "type": "object",
          "properties": {
            "omit": {
              "type": "boolean",
              "default": true,
              "description": "Specifies whether the security context should be adjusted for OpenShift"
            }
          }
        },
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "The parameter specifies whether the integration tests are installed or not. Set to true to run tests."
        },
        "sparkOperatorControllerDeploymentName": {
          "type": "string",
          "default": "sparkoperator-spark-operator-controller",
          "description": "Name of the Spark Operator Controller deployment"
        },
        "sparkOperatorWebhookDeploymentName": {
          "type": "string",
          "default": "sparkoperator-spark-operator-webhook",
          "description": "Name of the Spark Operator Webhook deployment"
        },
        "sparkAppsServiceAccount": {
          "type": "string",
          "default": "sparkapps-sa",
          "description": "The parameter specifies the service account name in the Spark apps namespace."
        }
      }
    },
    "statusProvisioner": {
      "type": "object",
      "properties": {
        "podSecurityContext": {
          "type": "object",
          "description": "Pod-level security context for the status provisionor Pod.",
          "$ref": "#/definitions/io.k8s.api.core.v1.PodSecurityContext",
          "default": {
            "runAsNonRoot": true,
            "seccompProfile": {
              "type": "RuntimeDefault"
            },
            "runAsUser": 185
          }
        },
        "securityContext": {
          "type": "object",
          "description": "Container-level security context for the status provisionor Pod.",
          "$ref": "#/definitions/io.k8s.api.core.v1.SecurityContext",
          "default": {
            "privileged": false,
            "allowPrivilegeEscalation": false,
            "capabilities": {
              "drop": [
                "ALL"
              ]
            },
            "readOnlyRootFilesystem": true
          }
        },
        "priorityClassName": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Priority class name for the status provisioner Pod."
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "The parameter specifies if the status provisioner job is deployed."
        },
        "resources": {
          "$ref": "#/definitions/io.k8s.api.core.v1.ResourceRequirements",
          "description": "Compute Resources required by status provisioner container. More info: https://kubernetes.io/docs/concepts/configuration/manage-resources-containers/",
          "default": {
            "limits": {
              "cpu": "200m",
              "memory": "200Mi"
            },
            "requests": {
              "cpu": "200m",
              "memory": "200Mi"
            }
          }
        },
        "image": {
          "type": "string",
          "default": "ghcr.io/netcracker/qubership-deployment-status-provisioner:0.1.4",
          "description": "The image for the Deployment Status Provisioner pod."
        },
        "lifetimeAfterCompletion": {
          "type": "integer",
          "default": 600,
          "description": "The number of seconds that the job remains alive after its completion."
        },
        "podReadinessTimeout": {
          "type": "integer",
          "default": 300,
          "description": "The timeout in seconds that the job waits for the monitored resources to be ready or completed."
        },
        "integrationTestsTimeout": {
          "type": "integer",
          "default": 2000,
          "description": "The timeout in seconds that the job waits for the integration tests to complete."
        },
        "labels": {
          "type": "object",
          "default": {},
          "description": "Labels to add to the status provisioner Pod",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "certManagerIntegration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether to enable cert-manager integration for automatic TLS certificate management for the Spark Operator."
        }
      }
    },
    "openShift": {
      "type": "object",
      "properties": {
        "omit": {
          "type": "boolean",
          "default": true,
          "description": "Specifies whether the security context should be adjusted for OpenShift"
        }
      }
    },
     "PAAS_PLATFORM": {
      "type": "string",
      "description": "The PaaS platform where spark is being deployed to."
    }
  }
}